//src/.env.example
# Supabase Configuration
VITE_SUPABASE_URL=your_supabase_project_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# Blockchain Configuration
VITE_CONTRACT_ADDRESS=your_deployed_contract_address_on_arbitrum
VITE_ARBITRUM_RPC=https://arbitrum-sepolia.infura.io/v3/YOUR_INFURA_KEY
VITE_ARB_EXPLORER_URL=https://sepolia.arbiscan.io/your_explorer_api_key

# IPFS/Pinata Configuration
VITE_PINATA_KEY=your_pinata_api_key
VITE_PINATA_SECRET=your_pinata_secret_key

# Supabase Edge Functions Environment (for mint-credential function)
# These need to be set in your Supabase project settings
ARBITRUM_RPC_URL=https://arbitrum-sepolia.infura.io/v3/YOUR_INFURA_KEY
BLOCKCHAIN_PRIVATE_KEY=your_ethereum_private_key_for_minting
PINATA_JWT=your_pinata_jwt_token